---
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
const { post } = Astro.props;

const readingTime =
  post.data.readingTime ??
  Math.ceil((post.body?.split("/\s+/g").length ?? 0) / 200);
---

<a
  href={`/blog/${post.id}`}
  class="group relative flex items-center gap-5 p-5 rounded-2xl
         bg-black/15 backdrop-blur-md
         border border-white/10
         transition-all duration-300
         hover:-translate-y-1 hover:shadow-xl hover:border-white/20"
>
  <!-- Cover Image -->
  <div
    class="relative w-20 h-20 shrink-0 overflow-hidden rounded-xl bg-white/5 flex items-center justify-center"
  >
    {
      post.data.cover ? (
        <Image
          src={post.data.cover}
          alt={post.data.title}
          class="w-full h-full object-cover transition duration-500 group-hover:scale-105"
          loading="lazy"
          width={80}
          height={80}
        />
      ) : (
        <span class="text-xs text-gray-500">No Image</span>
      )
    }
  </div>

  <!-- Content -->
  <div class="relative flex-1 space-y-2 min-h-3/4">
    <!-- Top Row -->
    <div class="flex items-start justify-between gap-3">
      <!-- Title + Description -->
      <div>
        <h3
          class="text-lg font-bold text-gray-100 group-hover:text-white transition"
        >
          {post.data.title}
        </h3>

        {
          post.data.description && (
            <p class="text-sm text-gray-400 font-mono">
              {post.data.description}
            </p>
          )
        }
      </div>
      <!-- stack dates -->
      <div class="flex flex-col items-end gap-1">
        <!-- Date -->
        <span
          class="flex items-center gap-1 text-xs text-gray-400 font-mono whitespace-nowrap"
        >
          <Icon name="mdi:calendar-range" class="w-3 h-3" />

          {
            new Date(post.data.date).toLocaleDateString("en-US", {
              month: "short",
              day: "numeric",
              year: "numeric",
            })
          }
        </span>

        {
          post.data.updated && post.data.updated !== post.data.date && (
            // show side by side icon and date
            <span class="flex items-center gap-1 text-xs text-gray-400 font-mono whitespace-nowrap">
              <Icon name="mdi:update" class="w-3 h-" />

              {new Date(post.data.updated).toLocaleDateString("en-US", {
                month: "short",
                day: "numeric",
                year: "numeric",
              })}
            </span>
          )
        }
      </div>
    </div>

    <!-- Meta Row -->
    <div class="flex flex-wrap items-center gap-2 text-xs">
      <!-- Reading Time -->
      <span
        class="flex items-center gap-1 px-2 py-0.5 rounded-full font-mono
                   bg-white/10 text-white/80 border border-white/20"
      >
        <Icon
          name="mdi:timer"
          class="w-3 h-3 text-gray-400 transition-opacity"
        />
        {readingTime} min
      </span>

      <!-- Draft Badge -->
      {
        post.data.draft && (
          <span
            class="px-2 py-0.5 rounded-full font-mono
                     bg-yellow-400/10 text-yellow-300 border border-yellow-400/20"
          >
            Draft
          </span>
        )
      }

      <!-- Tags -->
      {
        post.data.tags?.slice(0, 3).map((tag: string) => (
          <span
            class="flex items-center px-2 py-0.5 rounded-full font-mono
                     bg-white/5 text-gray-300 border border-white/10"
          >
            <Icon
              name="mdi:pound"
              class="w-3 h-3 text-gray-400 transition-opacity"
            />
            {tag}
          </span>
        ))
      }
    </div>
  </div>
</a>
