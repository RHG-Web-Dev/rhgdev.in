---
const loadDefault = false;
const backgrounds = {
  default: "1667242418056-a8dba5b0fc9b",
  summer: [
    "1541843713287-e0d5de49a384",
    "1512848857248-75eff50a19a1",
    "1544513169-0a660c85bdd9",
  ],
  spring: [
    "1591194577912-2c7811d0f994",
    "1541942172213-60aeb3558797",
    "1597086454462-1f9b6e95e1f7",
    "1520363027780-797c0e65eed5",
    "1631677209832-e9dd6aec3697",
  ],
  autumn: [
    "1507486411790-179bbb6866ed",
    "1550931937-2dfd45a40da0",
    "1508766229-1a45d4127740",
    "1509838174235-432f709c7bfd",
    "1634523453794-b992ac716fa3",
    "1633622667733-5de5e7ab9305",
    "1667748941477-28964059b86e",
    "1733503757968-b2281fbdd10b",
  ],
  winter: [
    "1515583484859-a15e976f80d2",
    "1483921020237-2ff51e8e4b22",
    "1456389573961-0ae56d45961e",
    "1641785680273-9017dd4cb5c9",
    "1588168000634-95b744f81f9f",
    "1667242418056-a8dba5b0fc9b",
  ],
};
---

<div
  id="background"
  class="fixed inset-0 -z-150 bg-cover bg-center bg-no-repeat transition-opacity duration-3000 animate-bg opacity-0"
  data-backgrounds={JSON.stringify(backgrounds)}
  data-load-default={loadDefault}
>
  <div
    class="pointer-events-none absolute inset-0 backdrop-blur-xs"
    style="background: linear-gradient(5deg, rgba(0,0,0,0.1), rgba(0,0,0,0.1));"
  >
  </div>
</div>

<style>
  @keyframes bg-pulse {
    0% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.1);
    }
    100% {
      transform: scale(1);
    }
  }

  .animate-bg {
    animation: bg-pulse 60s linear infinite;
  }
</style>

<script>
  const bg = document.getElementById("background");

  if (bg) {
    const backgrounds = JSON.parse(bg.dataset.backgrounds ?? "{}");
    const loadDefault = bg.dataset.loadDefault === "true";
    bg.removeAttribute("data-backgrounds");
    bg.removeAttribute("data-load-default");

    const season = (() => {
      const urlParams = new URLSearchParams(window.location.search);
      const seasonParam = urlParams.get("season");
      if (
        seasonParam &&
        ["spring", "summer", "autumn", "winter"].includes(seasonParam)
      )
        return seasonParam;
      const month = new Date().getMonth() + 1;
      if (month >= 3 && month <= 5) return "spring";
      if (month >= 6 && month <= 8) return "summer";
      if (month >= 9 && month <= 11) return "autumn";
      return "winter";
    })();

    const options = backgrounds?.[season];

    let selected = backgrounds.default;

    if (!loadDefault && Array.isArray(options) && options.length > 0) {
      selected = options[Math.floor(Math.random() * options.length)];
    }

    const bgUrl = `https://images.unsplash.com/photo-${selected}?auto=format&fit=crop&w=1920&q=80`;

    bg.style.backgroundImage = `url('${bgUrl}')`;
    const img = new Image();
    img.src = bgUrl;

    img.onload = () => {
      bg.classList.remove("opacity-0");
      bg.classList.add("opacity-100");
    };
  }
</script>
