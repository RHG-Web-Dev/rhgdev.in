---
const { Image } = await import("astro:assets");
const { device } = Astro.props;
---

<a
  href={`/devices/${device.id}`}
  class={`group relative flex items-center gap-5 p-5 rounded-2xl 
    bg-black/15 backdrop-blur-md
    border border-white/10
    transition-all duration-300
    hover:-translate-y-1 hover:shadow-xl hover:border-white/20
    }
  `}
>
  <!-- Image -->
  <div
    class="relative w-20 h-20 shrink-0 overflow-hidden rounded-xl bg-white/5 flex items-center justify-center"
  >
    {
      device.data.image ? (
        <Image
          src={device.data.image}
          alt={device.data.nickname}
          width="16"
          height="16"
          class="w-full h-full object-cover transition duration-500 group-hover:scale-105"
          loading="lazy"
        />
      ) : (
        <span class="text-xs text-gray-500">No Image</span>
      )
    }
  </div>

  <!-- Content -->
  <div class="relative flex-1 space-y-2 min-h-3/4">
    <!-- Top Row -->
    <div class="flex items-start justify-between gap-3">
      <!-- Title -->
      <div>
        <h3
          class="text-lg font-bold text-gray-100 group-hover:text-white transition"
        >
          {device.data.nickname || `${device.data.brand} ${device.data.model}`}
        </h3>
        {
          device.data.nickname && (
            <p class="text-sm text-gray-400 font-mono">
              {device.data.brand}
              {device.data.model}
            </p>
          )
        }
      </div>

      <span class="text-xs text-gray-400 font-mono whitespace-nowrap">
        {
          new Date(device.data.acquired).toLocaleDateString("en-US", {
            month: "short",
            day: "numeric",
            year: "numeric",
          })
        }
      </span>
    </div>

    <!-- Meta (under title, NOT on the right) -->
    <div class="flex flex-wrap items-center gap-2">
      {
        device.data.primary && (
          <span
            class="flex items-center gap-1 text-[10px] px-2 py-0.5 rounded-full font-mono
                       bg-white/10 text-white/80 border border-white/20"
          >
            <span class="text-yellow-500">★</span>
            Primary
          </span>
        )
      }

      {
        device.data.status && (
          <span
            class={`flex items-center gap-1 text-[10px] px-2 py-0.5 rounded-full font-mono
          ${
            device.data.status === "active"
              ? "bg-green-400/10 text-green-300 border border-green-400/20"
              : device.data.status === "retired"
                ? "bg-amber-400/10 text-amber-300 border border-amber-400/20"
                : device.data.status === "broken"
                  ? "bg-red-400/10 text-red-300 border border-red-400/20"
                  : "bg-gray-400/10 text-gray-400 border border-gray-500/20"
          }`}
          >
            <span
              class={`w-1.5 h-1.5 rounded-full
            ${
              device.data.status === "active"
                ? "bg-green-400"
                : device.data.status === "retired"
                  ? "bg-amber-500"
                  : device.data.status === "broken"
                    ? "bg-red-400"
                    : "bg-gray-400"
            }`}
            />
            {device.data.status.charAt(0).toUpperCase() +
              device.data.status.slice(1)}
          </span>
        )
      }
    </div>
  </div>
</a>
