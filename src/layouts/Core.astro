---
const props = Astro.props;
import "../styles/global.css";
import Meta from "../components/core/Meta.astro";
import Header from "../components/core/Header.astro";
import Background from "../components/core/Background.astro";
import Footer from "../components/core/Footer.astro";
---

<html lang="en" class="dark">
  <head>
    <Meta {...props} />
  </head>
  <body class="bg-black text-white select-none" oncontextmenu="return false;">
    <Background />
    <!-- <Header /> -->
    <slot />
    <Footer />
  </body>
</html>
