---
import Core from "../layouts/Core.astro";
---

<Core>
  <div
    class="flex flex-col items-center justify-center min-h-screen text-center"
  >
    <h1 class="text-6xl font-bold mb-4">404 - Page Not Found</h1>
    <p class="text-gray-400 text-xl mb-8">
      Sorry, the page you are looking for does not exist.
    </p>
    <a href="/" class="text-blue-500 hover:underline">Go back to Home</a>
  </div>
</Core>
