---
import { getCollection } from "astro:content";
import Core from "../../layouts/Core.astro";
import Card from "../../components/devices/Card.astro";
import { dev } from "astro";

const devices = await getCollection("devices");

devices.sort((a, b) => {
  const dateA = new Date(a.data.acquired).getTime();
  const dateB = new Date(b.data.acquired).getTime();
  return dateB - dateA;
});

const devicesByType = devices.reduce<Record<string, typeof devices>>((acc, device) => {
  const category = device.id.split("/")[0];

  if (!acc[category]) acc[category] = [];
  acc[category].push(device);

  return acc;
}, {});

const groupedDevices = Object.entries(devicesByType).sort(([a], [b]) => {
  if (a === "etc") return 1;
  if (b === "etc") return -1;
  return a.localeCompare(b);
});
---

<Core title="My Devices" description="A collection of my devices.">
  <section class="relative min-h-screen px-6 lg:px-16 py-24">

    <div class="max-w-6xl mx-auto space-y-16">

      <!-- Header -->
      <div class="text-center space-y-6
              bg-black/30 backdrop-blur-md
              border border-white/10
              rounded-2xl px-6 py-8
              shadow-lg
							text-md">
        <h1 class="text-5xl md:text-6xl font-bold fade-delay-1">
          Devices
        </h1>
				<p class="text-gray-400 text-sm">
          {devices.length} total device{devices.length !== 1 && "s"} across {groupedDevices.length} category{groupedDevices.length !== 1 && "s"}.
        </p>
				<a href="/" class="text-gray-400 hover:text-white transition">
          ← Back to Home
        </a>
      </div>

      <!-- Device Groups -->
      <div class="space-y-16">
        {
          groupedDevices.map(([type, devices], i) => (
            <div class="space-y-6 fade-up" style={`animation-delay: ${0.3 + i * 0.1}s`}>
              
              <!-- Category Header -->
              <div class="flex items-center gap-4">
                <a
                  href={`/devices/${type}`}
                  class="text-2xl md:text-3xl font-semibold text-gray-200 hover:text-white transition"
                >
                  {type.charAt(0).toUpperCase() + type.slice(1)}
                </a>
                <div class="flex-1 h-px bg-linear-to-r from-black to-transparent" />

								<span class="text-xs text-gray-500 font-mono">
									{devices.length} device{devices.length !== 1 && "s"}
								</span>
              </div>

              <!-- Cards -->
              <div class="grid sm:grid-cols-2 gap-6">
                {
                  devices.map((device: any) => (
                   <Card device={device} />
                  ))
                }
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Core>