---
import { getCollection, render } from "astro:content";
import Core from "../../layouts/Core.astro";

export async function getStaticPaths() {
  const devices = await getCollection("devices");

  return devices.map((device) => {
    return {
      params: {
        device: device.id,
      },
      props: {
        device,
      },
    };
  });
}

const { device } = Astro.props;
const { Content } = await render(device);
---

<Core
  title={`${device.data.nickname} > ${device.data.brand}`}
  description={device.data.model}
>
  <section class="relative min-h-screen px-6 lg:px-16 py-24">
    <!-- Background -->
    <div
      class="absolute inset-0 bg-linear-to-b from-black/10 to-black/40 pointer-events-none"
    >
    </div>

    <div class="max-w-5xl mx-auto space-y-16">
      <div
        class="text-center space-y-6
              bg-black/30 backdrop-blur-md
              border border-white/10
              rounded-2xl px-6 py-8
              shadow-lg
							text-md"
      >
        <div
          class="w-40 h-40 mx-auto rounded-2xl overflow-hidden bg-white/5 flex items-center justify-center"
        >
          {
            device.data.image ? (
              <img
                src={device.data.image}
                alt={device.data.nickname}
                class="w-full h-full object-cover"
              />
            ) : (
              <span class="text-gray-500 text-sm">No Image</span>
            )
          }
        </div>

        <!-- Title -->
        <div>
          <h1 class="text-4xl md:text-5xl font-bold text-gray-100">
            {
              device.data.nickname ||
                `${device.data.brand} ${device.data.model}`
            }
          </h1>
          {
            device.data.nickname && (
              <p class="text-gray-400 font-mono">
                {device.data.brand}
                {device.data.model}
              </p>
            )
          }
        </div>

        <!-- Meta -->
        <div class="flex justify-center flex-wrap gap-2">
          {
            device.data.primary && (
              <span
                class="flex items-center gap-1 text-xs px-3 py-1 rounded-full font-mono
                             bg-white/10 text-white/80 border border-white/20"
              >
                ★ Primary
              </span>
            )
          }

          {
            device.data.status && (
              <span
                class={`flex items-center gap-1 text-xs px-3 py-1 rounded-full font-mono ${
                  device.data.status === "active"
                    ? "bg-green-400/10 text-green-300 border border-green-400/20"
                    : device.data.status === "retired"
                      ? "bg-yellow-400/10 text-yellow-300 border border-yellow-400/20"
                      : "bg-gray-400/10 text-gray-400 border border-gray-500/20"
                }`}
              >
                ●{" "}
                {device.data.status.charAt(0).toUpperCase() +
                  device.data.status.slice(1)}
              </span>
            )
          }

          <span class="text-xs text-gray-400 font-mono px-3 py-1">
            Acquired{" "}
            {
              new Date(device.data.acquired).toLocaleDateString("en-US", {
                month: "long",
                year: "numeric",
              })
            }
          </span>
        </div>
        <a
          href={`/devices/${device.id.split("/")[0]}`}
          class="text-gray-400 hover:text-white transition"
        >
          ← Back to {
            device.id.split("/")[0].charAt(0).toUpperCase() +
              device.id.split("/")[0].slice(1)
          }
        </a>
      </div>

      <!-- 🧾 DETAILS GRID -->
      <div class="grid md:grid-cols-2 gap-8 space-y-16">
        <!-- Specs -->
        <div
          class="p-6 rounded-2xl bg-black/30 backdrop-blur-md
              border border-white/10"
        >
          <h2 class="text-lg font-semibold text-gray-200 mb-4">Details</h2>

          <div class="space-y-2 text-sm font-mono text-gray-300">
            <div class="flex justify-between">
              <span class="text-gray-500">Brand</span>
              <span>{device.data.brand}</span>
            </div>

            <div class="flex justify-between">
              <span class="text-gray-500">Model</span>
              <span>{device.data.model}</span>
            </div>
          </div>
        </div>

        <!-- Detailed Specs -->
        <div
          class="p-6 rounded-2xl bg-black/30 backdrop-blur-md
              border border-white/10"
        >
          <h2 class="text-lg font-semibold text-gray-200 mb-4">Specs</h2>

          <div class="space-y-2 text-sm font-mono text-gray-300">
            {
              device.data.specs &&
                Object.entries(device.data.specs).map(([key, value]) => (
                  <div class="flex justify-between">
                    <span class="text-gray-500">{key}</span>
                    <span>{String(value)}</span>
                  </div>
                ))
            }
          </div>
        </div>
      </div>

      <!-- Notes -->
      {
        device.body && (
          <div
            class="p-6 rounded-2xl bg-black/30 backdrop-blur-md
              border border-white/10"
          >
            <h2 class="text-lg font-semibold text-gray-200 mb-4">Notes</h2>

            <div class="prose prose-invert max-w-none">
              <Content />
            </div>
          </div>
        )
      }
    </div>
  </section>
</Core>
