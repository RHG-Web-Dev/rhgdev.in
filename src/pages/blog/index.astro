---
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import Core from "../../layouts/Core.astro";
import Card from "../../components/blog/Card.astro";

const posts = await getCollection("blog");

// filter drafts in production
const filteredPosts = posts.filter((p) => {
  return import.meta.env.DEV || !p.data.draft;
}).filter((p) => {
	const now = new Date();
	const postDate = new Date(p.data.date);
	return postDate <= now;
}).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const pinnedPosts = posts.filter((p) => p.data.pinned);

// group by year
const postsByYear = filteredPosts.reduce((acc, post) => {
  const year = new Date(post.data.date).getFullYear();

  if (!acc[year]) acc[year] = [];
  acc[year].push(post);

  return acc;
}, {} as Record<string, typeof filteredPosts>);

const grouped = Object.entries(postsByYear).sort(
  ([a], [b]) => Number(b) - Number(a)
);

const tags = Array.from(
	new Set(
		filteredPosts.flatMap((post) => post.data.tags ?? [])
	)
).sort();
---

<Core title="Blog" description="Thoughts, notes, and posts">
  <section class="relative min-h-screen px-6 lg:px-16 py-24">

    <div class="max-w-6xl mx-auto space-y-16">

      <!-- Header -->
      <div class="text-center space-y-6
              bg-black/30 backdrop-blur-md
              border border-white/10
              rounded-2xl px-6 py-8
              shadow-lg
							text-md">
        <h1 class="text-5xl md:text-6xl font-bold fade-delay-1">
          Blog
        </h1>
				
								<!-- show tags -->
								<div class="flex flex-wrap justify-center gap-2 mt-4 text-xs">
									{tags.map((tag) => (
										<a
											href={`/blog/tag/${tag}`}
											class="flex items-center px-3 py-1 rounded-full bg-white/5 border border-white/10
													 text-gray-300 hover:bg-white/10 transition"
										>
											<Icon
											name="mdi:pound"
											class="w-3 h-3 text-gray-400 transition-opacity"
										/>
										{tag}
										</a>
									))}
								</div>

        <p class="text-gray-400 text-sm">
          {filteredPosts.length} total post{filteredPosts.length !== 1 && "s"} across {grouped.length} year{grouped.length !== 1 && "s"}.
        </p>

        <a href="/" class="text-gray-400 hover:text-white transition">
          ← Back to Home
        </a>
      </div>
			<!-- Pinned Posts -->
			{pinnedPosts.length > 0 && (
				<div class="space-y-6">
					<div class="flex items-center gap-4">
						<h2 class="text-2xl md:text-3xl font-semibold text-gray-200 hover:text-white transition">
							Pinned
						</h2>
						<div class="flex-1 h-px bg-linear-to-r from-black to-transparent" />
					</div>
						<div class="grid sm:grid-cols-2 gap-6">
							{pinnedPosts.map((post) => (
								<Card post={post} />
							))}
						</div>
				</div>
			)}

      <!-- YEAR GROUPS -->
      <div class="space-y-16">

        {grouped.map(([year, posts], i) => (
          <div
            class="space-y-6"
            style={`animation-delay: ${0.2 + i * 0.1}s`}
          >

            <!-- Year Header (like your device categories) -->
            <div class="flex items-center gap-4">
              <a
                href={`/blog/${year}`}
                class="text-2xl md:text-3xl font-semibold text-gray-200 hover:text-white transition"
              >
                {year}
              </a>

              <!-- Split line -->
              <div class="flex-1 h-px bg-linear-to-r from-black to-transparent" />

              <span class="text-xs text-gray-500 font-mono">
                {posts.length} post{posts.length !== 1 && "s"}
              </span>
            </div>

            <!-- Cards -->
            <div class="grid sm:grid-cols-2 gap-6">
              {posts.filter((p) => {
	return !p.data.pinned;
}).map((post) => (
                <Card post={post} />
              ))}
            </div>

          </div>
        ))}

      </div>

    </div>
  </section>
</Core>