---
import { getCollection, render } from "astro:content";
import { Icon } from "astro-icon/components";
import Core from "../../layouts/Core.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");

  return posts.map((post) => ({
    params: {
      post: post.id,
    },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Core title={post.data.title}>
  <section class="relative min-h-screen px-6 lg:px-16 py-24">
    <div class="max-w-6xl mx-auto space-y-10">
      <!-- Header -->
      <div
        class="text-center space-y-6
              bg-black/30 backdrop-blur-md
              border border-white/10
              rounded-2xl px-6 py-8
              shadow-lg
							text-md"
      >
        <h1 class="text-4xl md:text-5xl font-bold text-gray-100">
          {post.data.title}
        </h1>
        <!-- Draft Warn -->
        {
          post.data.draft && (
            <div class="inline-flex items-center gap-2 text-sm text-yellow-400 bg-yellow-900/30 border border-yellow-700/50 rounded-full px-3 py-1">
              <Icon name="mdi:alert-circle" class="w-4 h-4" />
              Draft - Not Published
            </div>
          )
        }
        <!-- Tags -->
        {
          post.data.tags?.length > 0 && (
            <div class="flex flex-wrap justify-center gap-2">
              {post.data.tags.map((tag: string) => (
                <a
                  href={`/blog/tag/${tag}`}
                  class="flex items-center text-md px-2 py-0.5 rounded-full font-mono
               bg-white/5 text-gray-300 border border-white/10
               hover:bg-white/10 transition"
                >
                  <Icon
                    name="mdi:pound"
                    class="w-3 h-3 text-gray-400 transition-opacity"
                  />
                  {tag}
                </a>
              ))}
            </div>
          )
        }

        <!-- Meta -->
        <div class="flex flex-col items-center gap-2 text-gray-400 font-mono">
          <!-- Published date -->
          <div class="flex items-center gap-1">
            <Icon name="mdi:calendar-range" class="w-3 h-3 text-gray-400" />
            <span>
              {
                new Date(post.data.date).toLocaleDateString("en-US", {
                  month: "short",
                  day: "numeric",
                  year: "numeric",
                })
              }
            </span>
          </div>

          <!-- Updated date -->
          {
            post.data.updated && post.data.updated !== post.data.date && (
              <div class="flex items-center gap-1">
                <Icon name="mdi:update" class="w-3 h-3 text-gray-400" />
                <span>
                  Updated{" "}
                  {new Date(post.data.updated).toLocaleDateString("en-US", {
                    month: "short",
                    day: "numeric",
                    year: "numeric",
                  })}
                </span>
              </div>
            )
          }
          <!-- Read time -->
          {
            post.body && (
              <div class="flex items-center gap-1">
                <Icon name="mdi:timer" class="w-3 h-3 text-gray-400" />
                <span>
                  {Math.ceil((post.body?.split("/\s+/g").length ?? 0) / 200)}{" "}
                  min read
                </span>
              </div>
            )
          }
        </div>

        <a href="/blog" class="text-gray-400 hover:text-white transition">
          ← Back to Blog
        </a>
      </div>

      <!-- Content -->
      <article
        class="prose prose-invert bg-black/30 backdrop-blur-md
              border border-white/10
              rounded-2xl px-6 py-8
              shadow-lg"
      >
        <Content />
      </article>
    </div>
  </section>
</Core>
